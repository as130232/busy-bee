# Busy Bee 環境變數清單（複製為 busy-bee-be/.env.local 使用，不含真實值）

# 執行環境：local / qa / prod
APP_ENV=local

# HTTP
HTTP_PORT=8080

# Log：debug / info / warn / error
LOG_LEVEL=info

# PostgreSQL（對應 docker-compose.yml）
DB_URL=postgres://busybee:busybee@localhost:5432/busybee?sslmode=disable

# Redis（對應 docker-compose.yml）
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Firebase Auth（ID token 驗證只需 project ID）
FIREBASE_PROJECT_ID=

# 登入白名單：逗號分隔的 email 清單；留空 = fail-closed 拒絕所有人
ALLOWED_EMAILS=

# GCS 音訊儲存：bucket 名稱與簽名用 SA（本地經 impersonation 代簽，無金鑰檔）
GCS_BUCKET=
GCS_SIGNER_EMAIL=
